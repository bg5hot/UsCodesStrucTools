<UserControl x:Class="SpectrumComparison.PunchingShearView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpectrumComparison"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1200">

    <UserControl.DataContext>
        <local:PunchingShearViewModel/>
    </UserControl.DataContext>

    <Grid Background="{StaticResource FluentBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="16">
            <StackPanel>
                <TextBlock Text="ACI 318-19 双向板抗冲切验算" Style="{StaticResource SectionTitleStyle}"/>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="楼板参数" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="板厚 h (in):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding H, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="保护层 (in):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Cover, StringFormat=F2}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="板面钢筋:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding BarSizeOptions}" SelectedItem="{Binding SelectedBarSize}"
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="柱子参数" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="c₁ (in):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding C1, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="c₂ (in):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding C2, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="柱位置:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding ColumnLocationOptions}" SelectedItem="{Binding ColumnLocation}"
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="荷载参数" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Vu (kips):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Vu, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="Msc (kip-ft):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Msc, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="材料参数" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="f'c (psi):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Fc, StringFormat=F0}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="λ:" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Lambda, StringFormat=F2}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="箍筋fyt (psi):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Fyt, StringFormat=F0}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="栓钉fyt (psi):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding StudFyt, StringFormat=F0}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="抗剪钢筋/栓钉"  Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="类型:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding ReinforcementTypeOptions}" SelectedItem="{Binding ReinforcementType}"
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1"/>
                        </Grid>

                        <Grid Visibility="{Binding ShowReinforcementInputs, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="箍筋/栓钉规格:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding StudSizeOptions}" SelectedItem="{Binding StudSize}"
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="每周肢数/根数:" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <ComboBox ItemsSource="{Binding StudsPerPerimeterOptions}" SelectedItem="{Binding StudsPerPerimeter}"
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="3" Margin="0,0,8,0"/>
                            <TextBlock Text="间距(in):" Style="{StaticResource LabelStyle}" Grid.Column="4"/>
                            <TextBox Text="{Binding StudSpacing, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="5"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Content="执行验算" Command="{Binding CalculateCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,16"/>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="验算结果" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>

                        <TextBlock Text="{Binding ResultSummary}" Style="{StaticResource StrongLabelStyle}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="{Binding ReinforcementResult}" Style="{StaticResource LabelStyle}" TextWrapping="Wrap"/>

                        <Separator Style="{StaticResource SeparatorStyle}"/>

                        <TextBlock Text="临界截面属性:" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SectionProperties}" Style="{StaticResource LabelStyle}" FontFamily="Consolas" Margin="0,0,0,8"/>

                        <TextBlock Text="需求与承载力:" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding DemandVsCapacity}" Style="{StaticResource LabelStyle}" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1" Margin="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="详细计算过程" Style="{StaticResource SectionTitleStyle}"/>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="ACI 318-19 计算步骤:" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" Grid.Row="0"/>
                            <Border Background="#F5F5F5" BorderBrush="{StaticResource FluentBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Grid.Row="1">
                                <TextBox Text="{Binding DesignProcess}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="500"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
